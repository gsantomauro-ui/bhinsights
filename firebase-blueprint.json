{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "An article published on the HB Insights platform.",
      "type": "object",
      "properties": {
        "slug": { "type": "string", "description": "URL-friendly string for routing." },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "categorySlug": { "type": "string" },
        "authorName": { "type": "string" },
        "authorRole": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string", "format": "uri" },
        "readTime": { "type": "string" },
        "content": { "type": "string" },
        "featured": { "type": "boolean" },
        "isBreaking": { "type": "boolean" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "published": { "type": "boolean", "description": "Is the article published or a draft?" }
      },
      "required": ["slug", "title", "excerpt", "categoryId", "categoryName", "categorySlug", "authorName", "authorRole", "date", "imageUrl", "readTime", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "A user in the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "author"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Stores the articles for the platform."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user roles and profiles."
    }
  }
}
